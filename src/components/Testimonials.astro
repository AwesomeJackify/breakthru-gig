<section id="testimonials" class="py-24 bg-base-100">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Section header -->
    <div class="text-center mb-16">
      <p class="text-sm font-semibold uppercase tracking-widest opacity-50 mb-2">What Clients Say</p>
      <h2 class="text-4xl font-bold max-w-xl mx-auto leading-tight">
        Real people, real results with Breakthru
      </h2>
      <p class="mt-4 max-w-2xl mx-auto opacity-70">
        One to two sentences introducing the social proof section — clients from all backgrounds and levels who broke through to their goals with Myer's coaching.
      </p>
    </div>

    <!-- Testimonial card grid — 3 col desktop, 1 col mobile -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

      <!-- Testimonial 1 -->
      <!-- STARDRAFT: non-functional — replace with real client testimonial -->
      <div class="card card-border">
        <div class="card-body gap-4">

          <!-- Star rating -->
          <div class="rating rating-sm">
            <input type="radio" name="rating-t1" class="mask mask-star" aria-label="1 star" />
            <input type="radio" name="rating-t1" class="mask mask-star" aria-label="2 stars" />
            <input type="radio" name="rating-t1" class="mask mask-star" aria-label="3 stars" />
            <input type="radio" name="rating-t1" class="mask mask-star" aria-label="4 stars" />
            <input type="radio" name="rating-t1" class="mask mask-star" checked aria-label="5 stars" />
          </div>

          <p class="opacity-80">
            "Client name — one sentence describing their experience and result with Breakthru. Make it specific to the transformation achieved."
          </p>

          <!-- Author -->
          <div class="flex items-center gap-3 mt-2">
            <!-- STARDRAFT: non-functional — replace with real client avatar photo -->
            <div class="avatar avatar-placeholder">
              <div class="bg-neutral text-neutral-content w-10 rounded-full">
                <span class="text-sm">AB</span>
              </div>
            </div>
            <div>
              <p class="font-semibold text-sm">Client Name</p>
              <p class="text-xs opacity-50">Role or location — e.g. "Strength athlete, Auckland"</p>
            </div>
          </div>

        </div>
      </div>

