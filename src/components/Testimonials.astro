---
// Testimonials.astro — client testimonial card grid with star ratings and avatar placeholders
// STARDRAFT: all quotes, names, and avatars are placeholders — replace with real testimonials from Myer
import config from "../../breakthru.config.json";
const { testimonials } = config;
---

<section id="testimonials" class="py-24 bg-base-100">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Section header -->
    <div class="text-center mb-16">
      <p class="text-sm font-semibold uppercase tracking-widest opacity-50 mb-2">{testimonials.sectionLabel}</p>
      <h2 class="text-4xl font-bold max-w-xl mx-auto leading-tight">{testimonials.headline}</h2>
      <p class="mt-4 max-w-2xl mx-auto opacity-70">{testimonials.body}</p>
    </div>

    <!-- Testimonial card grid — 3 col desktop, 1 col mobile -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.cards.map((t, idx) => (
        <div class="card card-border">
          <div class="card-body gap-4">

            <!-- Star rating -->
            <div class="rating rating-sm">
              {Array.from({ length: 5 }, (_, i) => (
                <input
                  type="radio"
                  name={`rating-t${idx}`}
                  class="mask mask-star"
                  checked={i + 1 === t.rating}
                  aria-label={`${i + 1} star${i + 1 > 1 ? "s" : ""}`}
                />
              ))}
            </div>

            <p class="opacity-80">"{t.quote}"</p>

            <!-- Author -->
            <!-- STARDRAFT: replace avatar placeholder with real client photo -->
            <div class="flex items-center gap-3 mt-2">
              <div class="avatar avatar-placeholder">
                <div class="bg-neutral text-neutral-content w-10 rounded-full">
                  <span class="text-sm">{t.initials}</span>
                </div>
              </div>
              <div>
                <p class="font-semibold text-sm">{t.name}</p>
                <p class="text-xs opacity-50">{t.role}</p>
              </div>
            </div>

          </div>
        </div>
      ))}
    </div>

  </div>
</section>
