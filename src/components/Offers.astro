---
// Offers.astro — What Breakthru Offers: coaching approach and outcomes in card grid
import config from "../../breakthru.config.json";
const { offers } = config;
---

<section id="offers" class="py-24 bg-base-200">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Section header -->
    <div class="text-center mb-16">
      <p class="text-sm font-semibold uppercase tracking-widest opacity-50 mb-2">{offers.sectionLabel}</p>
      <h2 class="text-4xl font-bold max-w-xl mx-auto leading-tight">{offers.headline}</h2>
      <p class="mt-4 max-w-2xl mx-auto opacity-70">{offers.body}</p>
    </div>

    <!-- Offering cards — 3 col desktop, 1 col mobile -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {offers.cards.map((card) => (
        <div class="card card-border">
          <div class="card-body">
            <!-- Icon placeholder — replace with astro-icon at Liftoff -->
            <div class="skeleton w-10 h-10 mb-4 rounded-lg"></div>
            <h3 class="card-title">{card.title}</h3>
            <p>{card.body}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Section CTA -->
    <div class="text-center mt-12">
      <a href="#qualify" class="btn btn-primary btn-lg">{offers.cta}</a>
    </div>

  </div>
</section>
