---
import { Image } from "astro:assets";
import photo1 from "../assets/images/photo-gallery/photo-gallery1.jpeg";
import photo2 from "../assets/images/photo-gallery/photo-gallery2.jpeg";
import photo3 from "../assets/images/photo-gallery/photo-gallery3.jpeg";
import photo4 from "../assets/images/photo-gallery/photo-gallery4.jpeg";
import photo5 from "../assets/images/photo-gallery/photo-gallery5.jpeg";
---

<section class="py-8 md:py-24 bg-base-200 overflow-hidden">
  <div class="max-w-6xl mx-auto px-6">
    <!-- Section header -->
    <div class="text-center mb-8 md:mb-16">
      <p class="text-4xl uppercase tracking-widest mb-2 font-extrabold">
        Breakthru your limits
      </p>
      <h2 class="text-lg font-light">
        Home to all levels of fitness, <br />start your transformation today
      </h2>
    </div>

    <!-- Fan wrapper — scales down on mobile to match desktop layout exactly -->
    <div class="fan-wrapper">
      <div class="fan">
        <div
          class="absolute"
          style="transform: rotate(-12deg) translateX(-360px) translateY(10px); z-index: 1;"
        >
          <div class="hover-3d">
            <figure class="w-52 h-80 rounded-2xl overflow-hidden shadow-2xl">
              <Image
                src={photo1}
                alt="Myer Bevan"
                class="w-full h-full object-cover"
              />
            </figure>
            <div></div><div></div><div></div><div></div>
            <div></div><div></div><div></div><div></div>
          </div>
        </div>

        <div
          class="absolute"
          style="transform: rotate(-6deg) translateX(-185px) translateY(-8px); z-index: 2;"
        >
          <div class="hover-3d">
            <figure class="w-52 h-80 rounded-2xl overflow-hidden shadow-2xl">
              <Image
                src={photo2}
                alt="Myer Bevan coaching"
                class="w-full h-full object-cover"
              />
            </figure>
            <div></div><div></div><div></div><div></div>
            <div></div><div></div><div></div><div></div>
          </div>
        </div>

        <div
          class="absolute"
          style="transform: rotate(0deg) translateX(0px) translateY(0px); z-index: 3;"
        >
          <div class="hover-3d">
            <figure class="w-60 h-96 rounded-2xl overflow-hidden shadow-2xl">
              <Image
                src={photo3}
                alt="Myer Bevan training"
                class="w-full h-full object-cover"
              />
            </figure>
            <div></div><div></div><div></div><div></div>
            <div></div><div></div><div></div><div></div>
          </div>
        </div>

        <div
          class="absolute"
          style="transform: rotate(6deg) translateX(185px) translateY(-8px); z-index: 2;"
        >
          <div class="hover-3d">
            <figure class="w-52 h-80 rounded-2xl overflow-hidden shadow-2xl">
              <Image
                src={photo4}
                alt="Myer Bevan"
                class="w-full h-full object-cover"
              />
            </figure>
            <div></div><div></div><div></div><div></div>
            <div></div><div></div><div></div><div></div>
          </div>
        </div>

        <div
          class="absolute"
          style="transform: rotate(12deg) translateX(360px) translateY(10px); z-index: 1;"
        >
          <div class="hover-3d">
            <figure class="w-52 h-80 rounded-2xl overflow-hidden shadow-2xl">
              <Image
                src={photo5}
                alt="Myer Bevan"
                class="w-full h-full object-cover"
              />
            </figure>
            <div></div><div></div><div></div><div></div>
            <div></div><div></div><div></div><div></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Fan intrinsic size matches the desktop layout */
  .fan-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 500px;
  }

  .fan {
    position: relative;
    width: 950px;
    height: 500px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Scale the whole fan to fit mobile — same shape, just smaller */
  @media (max-width: 480px) {
    .fan-wrapper {
      height: 200px;
    }
    .fan {
      transform: scale(0.38);
      transform-origin: center center;
    }
  }
  @media (min-width: 481px) and (max-width: 767px) {
    .fan-wrapper {
      height: 280px;
    }
    .fan {
      transform: scale(0.55);
      transform-origin: center center;
    }
  }
</style>
