---
import { Image } from "astro:assets";
import photo1 from "../assets/images/photo-gallery/photo-gallery1.jpeg";
import photo2 from "../assets/images/photo-gallery/photo-gallery2.jpeg";
import photo3 from "../assets/images/photo-gallery/photo-gallery3.jpeg";
import photo4 from "../assets/images/photo-gallery/photo-gallery4.jpeg";
import photo5 from "../assets/images/photo-gallery/photo-gallery5.jpeg";
---

<section class="py-24 bg-base-200">
  <div class="max-w-6xl mx-auto px-6">
    <!-- Section header -->
    <div class="text-center mb-16">
      <p class="text-4xl uppercase tracking-widest mb-2 font-extrabold">
        Breakthru your limits
      </p>
      <h2 class="text-lg font-light">
        Home to all levels of fitness, start your transformation today
      </h2>
    </div>

    <!-- Mobile: 2-col grid with slight tilts -->
    <div class="grid grid-cols-2 gap-4 md:hidden">
      <div class="hover-3d" style="transform: rotate(-4deg);">
        <figure class="rounded-2xl overflow-hidden shadow-2xl">
          <Image
            src={photo1}
            alt="Myer Bevan"
            class="w-full h-full object-cover"
          />
        </figure>
        <div></div><div></div><div></div><div></div>
        <div></div><div></div><div></div><div></div>
      </div>
      <div class="hover-3d" style="transform: rotate(3deg) translateY(16px);">
        <figure class="rounded-2xl overflow-hidden shadow-2xl">
          <Image
            src={photo2}
            alt="Myer Bevan coaching"
            class="w-full h-full object-cover"
          />
        </figure>
        <div></div><div></div><div></div><div></div>
        <div></div><div></div><div></div><div></div>
      </div>
      <!-- Centre photo spans full width on mobile -->
      <div class="col-span-2 flex justify-center">
        <div class="hover-3d w-2/3">
          <figure class="rounded-2xl overflow-hidden shadow-2xl">
            <Image
              src={photo3}
              alt="Myer Bevan training"
              class="w-full h-full object-cover"
            />
          </figure>
          <div></div><div></div><div></div><div></div>
          <div></div><div></div><div></div><div></div>
        </div>
      </div>
      <div class="hover-3d" style="transform: rotate(-3deg) translateY(-8px);">
        <figure class="rounded-2xl overflow-hidden shadow-2xl">
          <Image
            src={photo4}
            alt="Myer Bevan"
            class="w-full h-full object-cover"
          />
        </figure>
        <div></div><div></div><div></div><div></div>
        <div></div><div></div><div></div><div></div>
      </div>
      <div class="hover-3d" style="transform: rotate(5deg);">
        <figure class="rounded-2xl overflow-hidden shadow-2xl">
          <Image
            src={photo5}
            alt="Myer Bevan"
            class="w-full h-full object-cover"
          />
        </figure>
        <div></div><div></div><div></div><div></div>
        <div></div><div></div><div></div><div></div>
      </div>
    </div>

    <!-- Desktop: overlapping fan -->
    <div class="relative hidden md:flex items-center justify-center h-[500px]">
      <!-- Photo 1 — far left, tilted left -->
      <div
        class="absolute"
        style="transform: rotate(-12deg) translateX(-360px) translateY(10px); z-index: 1;"
      >
        <div class="hover-3d">
          <figure class="w-52 h-80 rounded-2xl overflow-hidden shadow-2xl">
            <Image
              src={photo1}
              alt="Myer Bevan"
              class="w-full h-full object-cover"
            />
          </figure>
          <div></div><div></div><div></div><div></div>
          <div></div><div></div><div></div><div></div>
        </div>
      </div>

      <!-- Photo 2 — left of centre, slight tilt -->
      <div
        class="absolute"
        style="transform: rotate(-6deg) translateX(-185px) translateY(-8px); z-index: 2;"
      >
        <div class="hover-3d">
          <figure class="w-52 h-80 rounded-2xl overflow-hidden shadow-2xl">
            <Image
              src={photo2}
              alt="Myer Bevan coaching"
              class="w-full h-full object-cover"
            />
          </figure>
          <div></div><div></div><div></div><div></div>
          <div></div><div></div><div></div><div></div>
        </div>
      </div>

      <!-- Photo 3 — centre, straight, slightly bigger -->
      <div
        class="absolute"
        style="transform: rotate(0deg) translateX(0px) translateY(0px); z-index: 3;"
      >
        <div class="hover-3d">
          <figure class="w-60 h-96 rounded-2xl overflow-hidden shadow-2xl">
            <Image
              src={photo3}
              alt="Myer Bevan training"
              class="w-full h-full object-cover"
            />
          </figure>
          <div></div><div></div><div></div><div></div>
          <div></div><div></div><div></div><div></div>
        </div>
      </div>

      <!-- Photo 4 — right of centre, slight tilt -->
      <div
        class="absolute"
        style="transform: rotate(6deg) translateX(185px) translateY(-8px); z-index: 2;"
      >
        <div class="hover-3d">
          <figure class="w-52 h-80 rounded-2xl overflow-hidden shadow-2xl">
            <Image
              src={photo4}
              alt="Myer Bevan"
              class="w-full h-full object-cover"
            />
          </figure>
          <div></div><div></div><div></div><div></div>
          <div></div><div></div><div></div><div></div>
        </div>
      </div>

      <!-- Photo 5 — far right, tilted right -->
      <div
        class="absolute"
        style="transform: rotate(12deg) translateX(360px) translateY(10px); z-index: 1;"
      >
        <div class="hover-3d">
          <figure class="w-52 h-80 rounded-2xl overflow-hidden shadow-2xl">
            <Image
              src={photo5}
              alt="Myer Bevan"
              class="w-full h-full object-cover"
            />
          </figure>
          <div></div><div></div><div></div><div></div>
          <div></div><div></div><div></div><div></div>
        </div>
      </div>
    </div>
  </div>
</section>
