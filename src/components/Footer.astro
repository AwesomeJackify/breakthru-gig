---
import { Image } from "astro:assets";
import logo from "../assets/images/logo.png";
import config from "../../breakthru.config.json";
const { footer, nav } = config;
---

<footer class="border-t border-base-200 py-10 flex flex-col items-center gap-6 text-center">

  <!-- Logo -->
  <Image src={logo} alt={footer.businessName} class="h-10 w-auto" />

  <!-- Nav links -->
  <nav>
    <div class="flex flex-wrap justify-center gap-4 sm:gap-6">
      {nav.links.map((link) => (
        <a href={link.href.startsWith("#") ? `/${link.href}` : link.href} class="link link-hover text-sm">{link.label}</a>
      ))}
    </div>
  </nav>

  <!-- Legal links -->
  <div class="flex gap-4 text-sm opacity-50">
    <a href="/terms" class="link link-hover">Terms &amp; Conditions</a>
    <a href="/privacy" class="link link-hover">Privacy Policy</a>
  </div>

  <!-- Rights -->
  <p class="text-sm opacity-40">&copy; {new Date().getFullYear()} {footer.businessName}. All rights reserved.</p>

</footer>
