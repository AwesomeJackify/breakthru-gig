---
// Nav.astro — sticky top navbar with mobile dropdown and CTA
import { Image } from "astro:assets";
import logoImg from "../assets/images/logo.png";
import config from "../../breakthru.config.json";
const { nav } = config;
---

<div class="navbar sticky top-0 z-50 bg-base-100 border-b border-base-200">
  <div class="navbar-start">
    <a href="/" class="btn btn-ghost px-2">
      <Image src={logoImg} alt={nav.logoAlt} class="h-10 w-auto" />
    </a>
  </div>

  <!-- Desktop nav links — hidden on mobile -->
  <div class="navbar-center hidden lg:flex">
    <ul class="menu menu-horizontal">
      {
        nav.links.map((link) => (
          <li>
            <a href={link.href.startsWith("#") ? `/${link.href}` : link.href}>
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>

  <div class="navbar-end">
    <!-- Desktop CTA -->
    <a href="/#services" class="btn btn-primary hidden lg:flex">{nav.cta}</a>

    <!-- Mobile hamburger -->
    <div class="dropdown dropdown-end lg:hidden">
      <button
        tabindex="0"
        class="btn btn-ghost"
        id="mobile-menu-btn"
        aria-label="Open menu"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
      <ul
        tabindex="0"
        class="menu menu-sm dropdown-content mt-3 z-1 p-2 shadow bg-base-100 rounded-box w-52"
      >
        {
          nav.links.map((link) => (
            <li>
              <a href={link.href.startsWith("#") ? `/${link.href}` : link.href}>
                {link.label}
              </a>
            </li>
          ))
        }
        <li>
          <a href="/#services" class="btn btn-primary btn-sm mt-2">{nav.cta}</a>
        </li>
      </ul>
    </div>
  </div>
</div>
