---
// Services.astro — Coaching packages / service tiers
import { Icon } from "astro-icon/components";
import config from "../../breakthru.config.json";
const { services } = config;
---

<section id="services" class="py-24 bg-base-100">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Section header -->
    <div class="text-center mb-16">
      <h2 class="text-xl font-light tracking-widest uppercase max-w-xl mx-auto">{services.headline}</h2>
      <p class="mt-3 max-w-2xl mx-auto opacity-70 text-sm">{services.body}</p>
    </div>

    <!-- Service tier cards — 3 col desktop, 1 col mobile -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-stretch">
      {services.tiers.map((s) => (
        <div class={`card card-border flex flex-col relative${s.popular ? " border-2 border-primary" : ""}`}>
          {s.popular && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2">
              <span class="badge badge-primary text-xs font-semibold uppercase tracking-wider px-4 py-3">Most Popular</span>
            </div>
          )}
          <div class="card-body flex flex-col gap-4">
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest opacity-50 mb-1">{s.tier}</p>
              <h3 class="text-2xl font-bold">{s.title}</h3>
              <p class="mt-2 opacity-70 text-sm">{s.description}</p>
            </div>

            <!-- Feature list -->
            <ul class="space-y-2 text-sm flex-1">
              {s.features.map((feature) => (
                <li class="flex items-start gap-2">
                  <Icon name="lucide:check-circle" class="w-4 h-4 mt-0.5 text-accent shrink-0" />
                  <span>{feature}</span>
                </li>
              ))}
            </ul>

          </div>
        </div>
      ))}
    </div>


  </div>
</section>
