---
// About.astro — two-column layout: video left, copy right; optional stats row below
import workoutVideo from '../assets/videos/workout video-portrait.mp4';
import config from "../../breakthru.config.json";
const { about } = config;
---

<section id="about" class="py-24">
  <div class="max-w-6xl mx-auto px-6">

    <p class="text-sm font-semibold uppercase tracking-widest opacity-50 mb-2">{about.sectionLabel}</p>

    <div class="flex flex-col lg:flex-row gap-16 items-center">

      <!-- Workout video — autoplay loop, no controls -->
      <div class="w-full lg:w-1/2 flex-shrink-0">
        <video
          src={workoutVideo}
          autoplay
          muted
          loop
          playsinline
          class="w-full aspect-[9/16] object-cover rounded-xl shadow-2xl"
          aria-label={about.videoAlt}
        ></video>
      </div>

      <!-- Copy column -->
      <div class="w-full lg:w-1/2 flex flex-col gap-6">
        <h2 class="text-4xl font-bold leading-tight">{about.headline}</h2>

        {about.paragraphs.map((p) => <p>{p}</p>)}

        <div class="flex flex-col sm:flex-row gap-4 mt-2">
          {about.stats.map((stat) => (
            <div class="card card-border flex-1">
              <div class="card-body items-center text-center">
                <div class="text-3xl font-bold">{stat.value}</div>
                <p class="text-sm opacity-60">{stat.label}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>
