---
// Hero.astro — full-height hero with image left, headline + CTAs right
import { Image } from 'astro:assets';
import heroImg from '../assets/images/hero.jpeg';
---

<section id="hero" class="hero min-h-[85vh] bg-base-200">
  <div class="hero-content flex-col lg:flex-row gap-12 max-w-6xl px-6 py-16">

    <!-- Hero image -->
    <div class="w-full lg:w-1/2 flex-shrink-0">
      <Image
        src={heroImg}
        alt="Myer Bevan — Breakthru online personal trainer"
        class="w-full rounded-xl shadow-2xl object-cover max-h-[600px]"
      />
    </div>

    <!-- Copy column -->
    <div class="w-full lg:w-1/2 flex flex-col gap-6">

      <!-- Eyebrow label -->
      <span class="badge badge-outline">Online Personal Training</span>

      <h1 class="text-5xl font-bold leading-tight">
        Your headline here — one bold statement that captures the Breakthru transformation promise
      </h1>

      <p class="text-xl opacity-70">
        Two to three sentences describing who Myer coaches, what makes Breakthru different, and the outcome clients can expect — sustainable strength, confidence, and real results.
      </p>

      <div class="flex flex-col sm:flex-row gap-4">
        <a href="#qualify" class="btn btn-primary btn-lg">Start Your Breakthru</a>
        <a href="#about" class="btn btn-outline btn-lg">Meet Myer</a>
      </div>

      <!-- Social proof line -->
      <p class="text-sm opacity-50">
        One-line trust signal — e.g. "Trusted by athletes and beginners across 20+ countries"
      </p>

    </div>
  </div>
</section>
