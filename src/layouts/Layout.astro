---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Breakthru",
  description = "Online personal training by Myer Bevan — sustainable strength and transformation.",
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="wireframe" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
