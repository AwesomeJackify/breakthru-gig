---
import "../styles/global.css";
import DashboardNav from "../components/DashboardNav.astro";
import { Icon } from "astro-icon/components";

interface Props {
  title?: string;
}

const { title = "Member's Zone — Breakthru" } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="breakthru" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body class="h-full bg-base-100">
    <!-- DaisyUI drawer: sidebar on desktop, slide-out on mobile -->
    <div class="drawer lg:drawer-open h-full">
      <input id="dashboard-drawer" type="checkbox" class="drawer-toggle" />

      <!-- Page content -->
      <div class="drawer-content flex flex-col h-full">
        <!-- Mobile top bar -->
        <header class="lg:hidden flex items-center gap-3 px-4 py-3 border-b border-base-300 bg-base-200 sticky top-0 z-30">
          <label for="dashboard-drawer" class="btn btn-ghost btn-sm" aria-label="Open menu">
            <Icon name="lucide:menu" class="h-5 w-5" />
          </label>
          <span class="font-semibold text-sm">Member's Zone</span>
        </header>

        <!-- Main content area -->
        <main class="flex-1 overflow-y-auto">
          <slot />
        </main>
      </div>

      <!-- Sidebar -->
      <div class="drawer-side z-40">
        <label for="dashboard-drawer" aria-label="Close menu" class="drawer-overlay"></label>
        <DashboardNav />
      </div>
    </div>
  </body>
</html>
