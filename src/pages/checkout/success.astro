---
import DashboardLayout from "../../layouts/DashboardLayout.astro";

const sessionId = Astro.url.searchParams.get("session_id");
if (!sessionId) return Astro.redirect("/subscribe");
---

<DashboardLayout title="Payment confirmed — Breakthru">
  <main class="min-h-screen flex items-center justify-center px-6 py-10">
    <div class="max-w-md w-full text-center">
      <div class="text-6xl mb-6">🎉</div>
      <h1 class="text-3xl font-bold mb-3">You're in!</h1>
      <p class="text-base-content/60 mb-8">
        Payment confirmed. Your Breakthru access is now active. Time to get to work.
      </p>
      <div class="flex flex-col gap-3">
        <a href="/dashboard" class="btn btn-primary btn-lg w-full">Go to dashboard</a>
        <a href="/videos" class="btn btn-outline w-full">Browse videos</a>
      </div>
    </div>
  </main>
</DashboardLayout>
