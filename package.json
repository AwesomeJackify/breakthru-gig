{
  "name": "breakthru",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "npm run lint && astro dev",
    "build": "npm run lint && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint src/**/*.{js,ts,jsx,tsx,astro} --no-error-on-unmatched-pattern",
    "lint:fix": "eslint src/**/*.{js,ts,jsx,tsx,astro} --no-error-on-unmatched-pattern --fix",
    "prepare": "husky",
    "generate-types": "wrangler types"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,astro}": "eslint --fix --no-warn-ignored"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.2",
    "@astrojs/node": "^10.0.6",
    "@iconify-json/lucide": "^1.2.98",
    "@mux/mux-node": "^14.0.1",
    "@mux/upchunk": "^3.5.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.1",
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^6.1.9",
    "astro-icon": "^1.1.5",
    "daisyui": "^5.5.19",
    "gsap": "^3.14.2",
    "split-type": "^0.3.4",
    "stripe": "^22.1.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript-eslint": "^8.57.0",
    "wrangler": "^4.74.0"
  }
}
