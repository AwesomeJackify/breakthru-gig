{
  "name": "breakthru",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "npm run lint && astro dev",
    "build": "npm run lint && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint src/**/*.{js,ts,jsx,tsx,astro} --no-error-on-unmatched-pattern",
    "lint:fix": "eslint src/**/*.{js,ts,jsx,tsx,astro} --no-error-on-unmatched-pattern --fix",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,astro}": "eslint --fix"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^6.0.4",
    "daisyui": "^5.5.19",
    "gsap": "^3.14.2",
    "split-type": "^0.3.4",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript-eslint": "^8.57.0"
  }
}
